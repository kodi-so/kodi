FROM oven/bun:1.1-alpine
WORKDIR /app

COPY . .
RUN bun install

ENV NODE_ENV=production

EXPOSE 3002

# Run migrations then start the server.
# migrate.ts uses drizzle-orm/migrator (programmatic, no CLI dependency).
# It exits 0 if already up-to-date, so this is safe on every boot.
CMD ["sh", "-c", "cd packages/db && bun run db:migrate && cd /app && bun run apps/api/src/index.ts"]
