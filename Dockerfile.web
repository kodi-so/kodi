FROM oven/bun:1.1-alpine
WORKDIR /app

COPY . .
RUN bun install

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

# NEXT_PUBLIC_* vars must be present at build time (they get baked into the JS bundle).
# Railway passes these as build args — declare them here so Docker makes them available.
ARG NEXT_PUBLIC_APP_URL
ENV NEXT_PUBLIC_APP_URL=$NEXT_PUBLIC_APP_URL

ARG NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL

RUN cd apps/web && bun run build

EXPOSE 3000

# next.config.mjs uses output: 'standalone', so we must use node server.js (not next start).
# Static assets and public dir need to be in place alongside the standalone bundle.
RUN cp -r /app/apps/web/.next/static /app/apps/web/.next/standalone/apps/web/.next/static 2>/dev/null || true \
 && cp -r /app/apps/web/public /app/apps/web/.next/standalone/apps/web/public 2>/dev/null || true
CMD ["node", "/app/apps/web/.next/standalone/apps/web/server.js"]
