# syntax=docker/dockerfile:1
# ---- deps ----
FROM oven/bun:1.1-alpine AS deps
WORKDIR /app

COPY package.json ./
COPY apps/web/package.json ./apps/web/
COPY packages/ui/package.json ./packages/ui/
COPY packages/typescript-config/package.json ./packages/typescript-config/

RUN bun install --no-cache

# ---- builder ----
FROM oven/bun:1.1-alpine AS builder
WORKDIR /app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

COPY --from=deps /app/node_modules ./node_modules
COPY . .

RUN mkdir -p apps/web/public && cd apps/web && bun run build

# Show standalone structure to confirm paths
RUN ls -la apps/web/.next/standalone/ && echo "server.js exists:" && test -f apps/web/.next/standalone/server.js && echo "YES" || echo "NO"

# ---- runner ----
FROM node:20-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV HOSTNAME="0.0.0.0"
ENV PORT=3000

RUN addgroup --system --gid 1001 nodejs && adduser --system --uid 1001 nextjs

# Copy standalone (includes bundled node_modules with next)
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/standalone ./
# Static files served by Next.js standalone
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/static ./.next/static
# Public dir
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/public ./public

USER nextjs
EXPOSE 3000

CMD ["node", "server.js"]
