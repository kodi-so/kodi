# ── Required (Phase 0) ────────────────────────────────────────────────────────

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/kodi

# Auth
BETTER_AUTH_URL=http://localhost:3001
BETTER_AUTH_SECRET=generate-with-openssl-rand-hex-32-minimum-32-chars

# Encryption (generate: openssl rand -hex 32)
ENCRYPTION_KEY=

# Feature flags
# KODI_FEATURE_MEETING_INTELLIGENCE=false
KODI_FEATURE_ZOOM_COPILOT=false
KODI_FEATURE_TOOL_ACCESS=false

# ── Required in Phase 1 (meeting intelligence) ──────────────────────────────

# Recall.ai
# RECALL_API_KEY=
# RECALL_API_REGION=us-east-1
# RECALL_API_BASE_URL=https://us-east-1.recall.ai
#
# Real-time events can be delivered to a per-bot webhook endpoint.
# RECALL_REALTIME_WEBHOOK_URL=http://localhost:3002/webhooks/recall/realtime
# RECALL_REALTIME_AUTH_TOKEN=
#
# Recall bot status webhooks and realtime webhook verification may use distinct secrets.
# RECALL_WEBHOOK_SECRET=
# RECALL_BOT_STATUS_WEBHOOK_SECRET=

# ── Required in Phase 1 (Zoom copilot) ──────────────────────────────────────

# Zoom
# ZOOM_CLIENT_ID=
# ZOOM_CLIENT_SECRET=
# ZOOM_WEBHOOK_SECRET=
# ZOOM_REDIRECT_URI=http://localhost:3002/integrations/zoom/callback
# ZOOM_APP_ID=
# ZOOM_ACCOUNT_ID=
# ZOOM_GATEWAY_URL=http://localhost:3010
# ZOOM_GATEWAY_INTERNAL_TOKEN=

# Composio tool access
# COMPOSIO_API_KEY=
# COMPOSIO_WEBHOOK_SECRET=
# COMPOSIO_BASE_URL=https://backend.composio.dev
# COMPOSIO_OAUTH_REDIRECT_URL=http://localhost:3001/settings/integrations/tool-access
# COMPOSIO_AUTH_CALLBACK_URL=http://localhost:3002/integrations/composio/callback
# COMPOSIO_MANAGE_CONNECTIONS_IN_CHAT=false
#
# Optional auth config ids for toolkits using Composio custom auth configs
# COMPOSIO_AUTH_CONFIG_GOOGLE=
# COMPOSIO_AUTH_CONFIG_SLACK=
# COMPOSIO_AUTH_CONFIG_GITHUB=
# COMPOSIO_AUTH_CONFIG_LINEAR=
# COMPOSIO_AUTH_CONFIG_NOTION=
#
# Optional provider credentials for Kodi-owned OAuth apps used through
# Composio custom auth configs
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ── Required in Phase 1 (provisioning) ───────────────────────────────────────

# AWS
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
# AWS_SECURITY_GROUP_ID=sg-...
# AWS_SUBNET_ID=subnet-...
# AWS_AMI_ID=ami-...

# Cloudflare
# CLOUDFLARE_API_TOKEN=...
# CLOUDFLARE_ZONE_ID=...

# LiteLLM
# LITELLM_PROXY_URL=http://localhost:4000
# LITELLM_MASTER_KEY=sk-...

# Instance defaults (optional — override to change instance size/credits)
# INSTANCE_TYPE=t4g.small
# INSTANCE_VOLUME_GB=20
# INSTANCE_CREDITS_DOLLARS=15
# BASE_DOMAIN=agent.kodi.so

# ── Required in Phase 2 (chat proxy) ─────────────────────────────────────────

# Local dev fallback URL for OpenClaw instance (used when no EC2 instance is provisioned).
# Point this at a locally running OpenClaw instance to test the chat proxy without AWS.
OPENCLAW_DEV_URL=

# ── Required in Phase 3 (invite flow) ────────────────────────────────────────

# JWT secret for signing invite tokens (generate: openssl rand -hex 32)
INVITE_JWT_SECRET=

# Public URL of the app (used in invite emails)
APP_URL=https://app.kodi.so

# Resend API key for sending invite emails (optional in dev — logs link to console instead)
# RESEND_API_KEY=re_...
