# ── Required (Phase 0) ────────────────────────────────────────────────────────

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/kodi

# Auth
BETTER_AUTH_URL=http://localhost:3001
BETTER_AUTH_SECRET=generate-with-openssl-rand-hex-32-minimum-32-chars
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Encryption (generate: openssl rand -hex 32)
ENCRYPTION_KEY=

# ── Required in Phase 1 (provisioning) ───────────────────────────────────────

# AWS
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
# AWS_SECURITY_GROUP_ID=sg-...
# AWS_SUBNET_ID=subnet-...
# AWS_AMI_ID=ami-...

# Cloudflare
# CLOUDFLARE_API_TOKEN=...
# CLOUDFLARE_ZONE_ID=...

# LiteLLM
# LITELLM_PROXY_URL=http://localhost:4000
# LITELLM_MASTER_KEY=sk-...

# ── Required in Phase 2 (billing) ────────────────────────────────────────────

# Stripe
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# API
NEXT_PUBLIC_API_URL=http://localhost:3002

# ── Phase 3 (invite flow) ─────────────────────────────────────────────────────

# Public URL of the app (used for invite redirects; defaults to window.location.origin in browser)
# APP_URL=https://app.kodi.so
