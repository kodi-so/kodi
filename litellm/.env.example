# === AI Provider API Keys ===
MOONSHOT_API_KEY=...

# === LiteLLM ===
LITELLM_MASTER_KEY=           # Auto-generated by deploy.sh if left empty

# === SSH ===
SSH_KEY_PATH=~/.ssh/id_ed25519     # Your local private key (public key auto-imported to AWS)

# === AWS ===
# Create an IAM user → Security credentials → Create access key → "Command Line Interface (CLI)"
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1

# === Cloudflare ===
CLOUDFLARE_API_TOKEN=...
CLOUDFLARE_ZONE_ID=...

# === Proxy hostname ===
PROXY_HOSTNAME=ai.kodi.so
