{
  "name": "kodi",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "pr:check": "bun scripts/pr-check.ts",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "turbo": "^2.0.0",
    "typescript": "^5.4.5"
  },
  "packageManager": "bun@1.2.0",
  "overrides": {
    "drizzle-orm": "^0.45.1"
  },
  "dependencies": {
    "tailwindcss-animate": "^1.0.7"
  }
}
